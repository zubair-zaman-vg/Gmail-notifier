<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Settings &amp; Tools"
            app:titleTextColor="@color/black"
            app:navigationIcon="@android:drawable/ic_menu_revert"
            app:navigationIconTint="@color/black" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APP CUSTOMIZATION"
                android:textColor="@color/text_grey"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManageFilters"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="32dp"
                android:text="Edit Notification Keywords"
                android:textColor="@color/black"
                app:icon="@android:drawable/ic_menu_edit"
                app:iconTint="@color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PERMISSION MANAGEMENT"
                android:textColor="@color/text_grey"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNotifyAccess"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:text="Notification Access"
                android:textColor="@color/black"
                app:icon="@android:drawable/ic_lock_idle_alarm"
                app:iconTint="@color/black" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOverlayPerm"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:text="Popup (Overlay) Permission"
                android:textColor="@color/black"
                app:icon="@android:drawable/ic_menu_slideshow"
                app:iconTint="@color/black" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBatteryOptim"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="32dp"
                android:text="Battery Optimization"
                android:textColor="@color/black"
                app:icon="@android:drawable/ic_lock_power_off"
                app:iconTint="@color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SYSTEM TOOLS"
                android:textColor="@color/text_grey"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRepairService"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@color/black"
                android:text="Repair &amp; Restart Service"
                android:textColor="@color/white"
                app:icon="@android:drawable/ic_menu_rotate"
                app:iconTint="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTestAlert"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Launch Test Alert"
                android:textColor="@color/black"
                app:icon="@android:drawable/ic_media_play"
                app:iconTint="@color/black" />

            <TextView
                android:id="@+id/tvLastPackage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Last seen: None"
                android:textAlignment="center"
                android:textColor="@color/text_grey"
                android:textSize="11sp"
                android:layout_marginTop="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Version 2.0.1 - Royal Monochrome Edition"
                android:textAlignment="center"
                android:textColor="@color/text_grey"
                android:textSize="10sp"
                android:layout_marginTop="48dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
